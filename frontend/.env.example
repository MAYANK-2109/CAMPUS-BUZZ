# Campus Buzz – Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────────────────
# The base URL of the Express REST API (must end with /api).
# Development:  http://localhost:5000/api
# Production:   https://your-render-backend.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api

# ── Backend Socket.io URL ─────────────────────────────────────────────────────
# The base URL of the Socket.io server (no /api suffix).
# Must point to the same backend as REACT_APP_API_URL.
# Development:  http://localhost:5000
# Production:   https://your-render-backend.onrender.com
#
# NOTE: On Vercel (serverless), this MUST be set explicitly.
#       If left unset in production, the socket connection will be disabled.
REACT_APP_SOCKET_URL=http://localhost:5000
