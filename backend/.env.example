# Campus Buzz – Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
# Set to 'production' on your hosting platform (Render, Railway, etc.)
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
# Get this from: https://cloud.mongodb.com → your cluster → Connect
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/campusbuzz?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a random, hard-to-guess string of at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# The URL(s) your frontend is served from.
# In development: http://localhost:3000
# In production:  https://your-app.vercel.app
# Multiple origins can be comma-separated: https://app.vercel.app,http://localhost:3000
CLIENT_URL=http://localhost:3000

# ── SMTP (Email Sending) ──────────────────────────────────────────────────────
# Used for OTP verification emails and password-reset links.
# Recommended: Gmail with an App Password (not your main Gmail password).
# How to get a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an app password → copy the 16-character code below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_gmail_address@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_NAME=CampusBuzz
FROM_EMAIL=noreply@campusbuzz.com
